---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import AnimatedButton from '../components/AnimatedButton';
import ContributionGrid from '../components/ContributionGrid.astro';
import FunnyFeed from '../components/FunnyFeed';

const skills = [
  { name: 'Python', projects: ['neural-trader', 'squeaky-greyhound'] },
  { name: 'PyTorch', projects: ['neural-trader'] },
  { name: 'TensorFlow', projects: ['neural-trader'] },
  { name: 'ROS', projects: ['squeaky-greyhound'] },
  { name: 'Raisim', projects: ['squeaky-greyhound'] },
  { name: 'Controls Theory', projects: ['controls-ios-application', 'nawcad'] },
  { name: 'C++', projects: ['squeaky-greyhound'] },
  { name: 'Embodied AI', projects: ['mailclient'] }
];

const projects = {
  'squeaky-greyhound': {
    title: 'Squeaky and Greyhound',
    description: 'A 3D printed quadruped robot project featuring advanced inverse kinematics and a sleek mechanical design for enhanced mobility.',
    skills: ['Python', 'ROS', 'Raisim', 'C++'],
    href: '/squeaky-greyhound'
  },
  'nawcad': {
    title: 'Senior Design: NAWCAD',
    description: 'Integrated test stand system design connecting mechanical engineering with a drone\'s flight stack using a custom Matlab GUI.',
    skills: ['Controls Theory', 'Matlab'],
    href: '/nawcad'
  },
  'controls-ios-application': {
    title: 'Controls IOS Application',
    description: 'A personal project experimenting with PID control, Apple\'s Swift language, and custom UI design for simulating control systems.',
    skills: ['Controls Theory', 'Swift'],
    href: '/controls-ios-application'
  },
  'mailclient': {
    title: 'Prysm Mail',
    description: 'A new type of email client leveraging local LLMs for enhanced privacy and user experience.',
    skills: ['Swift', 'CoreML', 'Embodied AI', 'Natural Language Processing'],
    href: '/mailclient'
  },
  'neural-trader': {
    title: 'Neural Trader (AI Project)',
    description: 'A neural network based financial advisor built with Matlab\'s Neural Network Toolbox and Python for data scraping and analysis.',
    skills: ['Python', 'PyTorch', 'TensorFlow'],
    href: '/neural-trader'
  },
  'website': {
    title: 'This Website',
    description: 'Yes, I made this website from scratch! No online website builders here. Check out the source code on GitHub.',
    skills: ['Web Development', 'JavaScript', 'Astro'],
    href: '/website'
  }
};

const [featuredId, ...restIds] = Object.keys(projects);
const featuredProject = projects[featuredId];
const restProjects = restIds.map(id => ({ id, ...projects[id] }));
---

<Layout title="Vittorio Pastore - Portfolio">

  <!-- Hero: full-viewport, outside editorial-main -->
  <section class="hero">
    <div class="hero-shell">
      <div class="hero-inner">
        <p class="section-label hero-path">~/vittorio<span class="cursor">▋</span></p>
        <h1 class="hero-name">Vittorio<br/>Pastore</h1>
        <div class="hero-accent-line"></div>
        <p class="hero-bio">
          Robotics Researcher at Virginia Tech.<br/>
          Passionate about Reinforcement Learning, Music, and Photography.
        </p>
        <div class="hero-cta">
          <AnimatedButton text="View Projects" href="#projects" client:load />
          <AnimatedButton text="Contact Me" href="#contact" client:load />
        </div>
      </div>
      <div class="hero-photo-wrap">
        <img
          src="/vittoTransparent.png"
          alt="Vittorio Pastore with robots"
          class="hero-photo"
        />
      </div>
    </div>
  </section>

  <main class="editorial-main">
    <!-- Projects Section -->
    <section id="projects" class="editorial-section" data-scroll-section="projects">
      <div class="section-rule">
        <span class="section-number">01</span>
        <span class="rule-line"></span>
        <span class="section-title-label">projects</span>
      </div>

      <!-- Featured Project -->
      <div
        id={`project-${featuredId}`}
        class={`card card-hover featured-project ai-gradient-border`}
        data-skills={featuredProject.skills.join(',')}
      >
        <div class="featured-inner">
          <div class="featured-meta">
            <span class="section-label">featured</span>
            <h2 class="featured-title">{featuredProject.title}</h2>
          </div>
          <div class="featured-body">
            <p class="featured-description">{featuredProject.description}</p>
            <div class="skill-tags">
              {featuredProject.skills.map(skill => (
                <span class="skill-tag">{skill}</span>
              ))}
            </div>
            <AnimatedButton text="View Project" href={featuredProject.href} client:load />
          </div>
        </div>
      </div>

      <!-- Remaining Projects Grid -->
      <div class="projects-grid">
        {restProjects.map(({ id, title, description, skills: projectSkills, href }) => (
          <div
            id={`project-${id}`}
            class="card card-hover project-card"
            data-skills={projectSkills.join(',')}
          >
            <h3 class="project-title">{title}</h3>
            <p class="project-description">{description}</p>
            <div class="skill-tags">
              {projectSkills.map(skill => (
                <span class="skill-tag">{skill}</span>
              ))}
            </div>
            <AnimatedButton text="View Project" href={href} client:load />
          </div>
        ))}
      </div>
    </section>

    <!-- Skills Section -->
    <section id="skills" class="editorial-section" data-scroll-section="skills">
      <div class="section-rule">
        <span class="section-number">02</span>
        <span class="rule-line"></span>
        <span class="section-title-label">skills</span>
      </div>
      <div class="skills-scroll">
        {skills.map(skill => (
          <button
            class="skill-chip card card-hover"
            data-skill={skill.name}
          >
            {skill.name}
          </button>
        ))}
      </div>
    </section>

    <!-- Activity Section -->
    <section id="activity" class="editorial-section" data-scroll-section="activity">
      <div class="section-rule">
        <span class="section-number">03</span>
        <span class="rule-line"></span>
        <span class="section-title-label">activity</span>
      </div>
      <ContributionGrid />
      <div class="activity-bottom">
        <FunnyFeed client:load />
      </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="editorial-section contact-section" data-scroll-section="contact">
      <div class="section-rule">
        <span class="section-number">04</span>
        <span class="rule-line"></span>
        <span class="section-title-label">contact</span>
      </div>
      <div class="contact-inner">
        <p class="section-label">// get in touch</p>
        <h2 class="contact-heading">Let's work<br/>together.</h2>
        <div class="contact-links">
          <AnimatedButton text="LinkedIn" href="https://www.linkedin.com/in/vittorio-pastore-6474691b1/" client:load />
          <AnimatedButton text="GitHub" href="https://github.com/VittorioPastore" client:load />
          <AnimatedButton text="Email Me" href="mailto:vitto@vt.edu" client:load />
        </div>
      </div>
    </section>

  </main>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const skillButtons = document.querySelectorAll('[data-skill]');
    skillButtons.forEach(button => {
      button.addEventListener('click', () => {
        const skillName = button.getAttribute('data-skill');
        highlightProjects(skillName);
      });
    });

    // --- Minimal Scroll Effects ---

    const scrollStatusBar = document.getElementById('scroll-status-bar');
    const scrollSpinner = document.getElementById('scroll-spinner');
    const scrollPath = document.getElementById('scroll-path');
    const frames = ['⠋', '⠙', '⠹', '⠸', '⠼', '⠴', '⠦', '⠧', '⠇', '⠏'];
    
    const sections = Array.from(document.querySelectorAll('[data-scroll-section]'));
    
    // Store original text for scrambling
    document.querySelectorAll('.section-title-label').forEach(lbl => {
      lbl.setAttribute('data-original', lbl.textContent || '');
    });

    const intervals = new Map<HTMLElement | Element, ReturnType<typeof setInterval>>();
    const timeouts = new Map<HTMLElement | Element, ReturnType<typeof setTimeout>>();

    function typeCommand(element: HTMLElement | Element, prefix: string, command: string, finalPath: string) {
      if (!command) return;
      if (intervals.has(element)) clearInterval(intervals.get(element));
      if (timeouts.has(element)) clearTimeout(timeouts.get(element));
      
      let index = 0;
      element.innerHTML = `<span class="path-prefix">${prefix}</span>`;
      
      const interval = setInterval(() => {
        if (index <= command.length) {
          element.innerHTML = `<span class="path-prefix">${prefix}</span><span class="path-command">${command.substring(0, index)}</span>`;
          index++;
        } else {
          clearInterval(interval);
          const tid = setTimeout(() => {
            element.innerHTML = `<span class="path-prefix">${finalPath}</span>`;
          }, 350);
          timeouts.set(element, tid);
        }
      }, 40);
      intervals.set(element, interval);
    }

    function scrambleText(element: HTMLElement | Element, targetText: string) {
      if (!targetText) return;
      const chars = '!<>-_\\\\/[]{}—=+*^?#_';
      let iteration = -3; // Start negative for a visual pause
      if (intervals.has(element)) clearInterval(intervals.get(element));
      
      const interval = setInterval(() => {
        let currentString = '';
        for (let i = 0; i < targetText.length; i++) {
          if (i < Math.floor(iteration)) {
            currentString += targetText[i];
          } else {
            currentString += chars[Math.floor(Math.random() * chars.length)];
          }
        }
        element.textContent = currentString;
        
        if (iteration >= targetText.length) {
          clearInterval(intervals.get(element));
          element.textContent = targetText;
        }
        iteration += Math.random() * 1.5;
      }, 35);
      intervals.set(element, interval);
    }

    let ticking = false;
    let lastSectionKey = '';

    const updateScrollState = () => {
      const scrollY = window.scrollY;
      
      // Update global scroll variable for CSS parallax
      const maxScroll = Math.max(document.documentElement.scrollHeight - window.innerHeight, 1);
      document.documentElement.style.setProperty('--scroll-ratio', Math.min(Math.max(scrollY / maxScroll, 0), 1).toFixed(4));


      // 2. Identify active section based on scroll position crossing mid viewport
      let activeKey = '';
      for (let i = sections.length - 1; i >= 0; i--) {
        const rect = sections[i].getBoundingClientRect();
        if (rect.top <= window.innerHeight * 0.45) {
          activeKey = sections[i].getAttribute('data-scroll-section') || '';
          break;
        }
      }

      // Fallback: forcefully select the last section if we've scrolled all the way to the bottom
      const maxY = Math.max(document.documentElement.scrollHeight - window.innerHeight, 1);
      if (window.scrollY >= maxY - 10 && sections.length > 0) {
        activeKey = sections[sections.length - 1].getAttribute('data-scroll-section') || '';
      }

      // 3. Floating HUD logic
      if (scrollStatusBar && scrollPath) {
        const currentPathAttr = scrollPath.getAttribute('data-current');
        const prevDir = currentPathAttr || '~$'; // capture what it currently was to build the prompt
        const newDir = activeKey ? `~/${activeKey}$` : '~$';
        
        const cdTarget = activeKey ? activeKey : '~';
        const commandStr = ` cd ${cdTarget}`;
        
        if (currentPathAttr !== newDir) {
          scrollPath.setAttribute('data-current', newDir);
          typeCommand(scrollPath, prevDir, commandStr, newDir);
        }
      }
      
      // 4. Focus/Scramble the literal section header when coming into view
      if (activeKey !== lastSectionKey) {
        sections.forEach(sec => {
          const isMatch = sec.getAttribute('data-scroll-section') === activeKey;
          if (isMatch && !sec.classList.contains('is-active')) {
            sec.classList.add('is-active');
            const lbl = sec.querySelector('.section-title-label');
            if (lbl) {
              scrambleText(lbl, lbl.getAttribute('data-original') || '');
            }
          } else if (!isMatch) {
            sec.classList.remove('is-active');
          }
        });
        lastSectionKey = activeKey;
      }
    };

    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateScrollState();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
    
    // Fire once on layout load
    window.requestAnimationFrame(updateScrollState);
  });

  function highlightProjects(skillName: string | null) {
    if (!skillName) return;
    // Remove any existing highlights
    document.querySelectorAll('[id^="project-"]').forEach(project => {
      project.classList.remove('highlight');
    });

    // Find projects with matching skills
    const projectElements = document.querySelectorAll(`[data-skills*="${skillName}"]`);

    if (projectElements.length > 0) {
      // Scroll to the first matching project
      projectElements[0].scrollIntoView({ behavior: 'smooth', block: 'center' });

      // Highlight matching projects
      projectElements.forEach(project => {
        project.classList.add('highlight');

        // Remove highlight after a few seconds
        setTimeout(() => {
          project.classList.remove('highlight');
        }, 2000); // 2 seconds
      });
    }
  }
</script>
<style>
  .editorial-section[data-scroll-section] {
    transition: opacity 0.5s ease;
    opacity: 0.55;
  }

  .editorial-section.is-active {
    opacity: 1;
  }

  /* ── Layout ── */
  .editorial-main {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 2rem 8rem;
    min-width: 0;
    overflow-x: hidden;
    width: 100%;
  }

  /* ── Hero ── */
  .hero {
    width: 100%;
    max-width: 100%;
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .hero-shell {
    position: relative;
    width: 100%;
    max-width: 1240px;
    min-height: 100vh;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
  }

  /* Text: anchored to left edge */
  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 500px;
    width: 100%;
    padding: 8rem 3rem 8rem 0;
    transform: translate3d(0, calc(var(--scroll-ratio, 0) * -24px), 0);
  }

  /* Photo: right half — starts at 42% for more breathing room */
  .hero-photo-wrap {
    position: absolute;
    left: 42%;
    right: 0;
    top: 0;
    bottom: 0;
    z-index: 1;
    pointer-events: none;
    transform: translate3d(0, calc(var(--scroll-ratio, 0) * 85px), 0);
    opacity: calc(1 - (var(--scroll-ratio, 0) * 0.72));
  }

  /* Fade from dark on left edge — removed: colour overlay caused banding on transparent PNG */

  /* Amber bloom behind photo */
  .hero-photo-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 80% at 50% 50%, rgba(245, 158, 11, 0.04) 0%, transparent 60%);
    z-index: 0;
    pointer-events: none;
  }

  /* Bottom vignette */
  .hero::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 6rem;
    background: linear-gradient(to bottom, transparent, var(--bg-base));
    z-index: 3;
    pointer-events: none;
  }

  /* Photo contained within the right half — no overflow */
  /* Mask fades the left edge of the image itself — no colour overlay, no banding */
  .hero-photo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    z-index: 1;
    mask-image: linear-gradient(to right, transparent 0%, black 25%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 25%);
  }

  @media (max-width: 768px) {
    .hero-shell {
      padding: 0 1rem;
    }

    .hero-inner {
      max-width: 100%;
      padding: 6rem 0 4rem;
    }

    .hero-name {
      font-size: clamp(2.2rem, 13vw, 4.5rem);
    }

    .hero-bio {
      max-width: 100%;
      font-size: 1rem;
    }
    .hero-photo-wrap {
      display: none;
    }
  }

  .hero-path {
    display: inline-flex;
    align-items: center;
    gap: 0.1em;
    margin-bottom: 2rem;
  }

  .hero-name {
    font-size: clamp(3.5rem, 10vw, 8rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }

  .hero-accent-line {
    width: 4rem;
    height: 3px;
    background: var(--color-accent);
    margin-bottom: 1.75rem;
  }

  .hero-bio {
    font-size: 1.125rem;
    color: var(--color-muted);
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 480px;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    width: 100%;
  }

  /* ── Section rules ── */
  .editorial-section {
    margin-bottom: 6rem;
    min-width: 0;
  }

  .section-rule {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .section-number {
    font-family: monospace;
    font-size: 0.75rem;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .rule-line {
    position: relative;
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
    overflow: hidden;
  }

  .rule-line::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, #d97706 0%, #F59E0B 60%, transparent 100%);
    transform-origin: left center;
    transform: scaleX(calc(0.16 + (var(--scroll-ratio, 0) * 0.84)));
    opacity: 0.5;
    transition: opacity 0.25s ease;
  }

  .editorial-section.is-active .rule-line::after {
    opacity: 0.92;
  }

  .section-title-label {
    font-family: monospace;
    font-size: 0.75rem;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    text-transform: lowercase;
    white-space: nowrap;
  }

  /* ── Featured project ── */
  .featured-project {
    padding: 2.5rem;
    border-radius: 12px;
    margin-bottom: 1.5rem;
    max-width: 100%;
  }

  .featured-inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
    align-items: start;
    min-width: 0;
  }

  @media (max-width: 640px) {
    .featured-inner {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  .featured-meta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 0;
  }

  .featured-title {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-text);
    overflow-wrap: anywhere;
  }

  .featured-body {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    min-width: 0;
  }

  .featured-description {
    color: var(--color-muted);
    line-height: 1.7;
    font-size: 1rem;
    overflow-wrap: anywhere;
  }

  /* ── Rest of projects grid ── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    min-width: 0;
    width: 100%;
    max-width: 100%;
  }

  @media (max-width: 640px) {
    .editorial-main {
      padding: 0 0.875rem 6rem;
    }

    .featured-project {
      padding: 1rem;
    }

    .project-card {
      padding: 1rem;
    }

    .section-rule {
      gap: 0.5rem;
      flex-wrap: wrap;
      align-items: flex-start;
    }

    .projects-grid {
      grid-template-columns: 1fr;
    }
  }

  .project-card {
    padding: 1.75rem;
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-width: 0;
    width: 100%;
  }

  .project-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    overflow-wrap: anywhere;
  }

  .project-description {
    color: var(--color-muted);
    font-size: 0.875rem;
    line-height: 1.65;
    flex: 1;
    overflow-wrap: anywhere;
  }

  /* ── Skill tags ── */
  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .skill-tag {
    font-size: 0.7rem;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    color: var(--color-muted);
    font-family: monospace;
  }

  /* ── Skills scroll row ── */
  .skills-scroll {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    min-width: 0;
    width: 100%;
    max-width: 100%;
  }

  .skill-chip {
    font-size: 0.8rem;
    font-family: monospace;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    cursor: pointer;
    color: var(--color-text);
    white-space: nowrap;
    transition: border-color 0.2s, color 0.2s;
  }

  .skill-chip:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* ── Activity ── */
  .activity-bottom {
    margin-top: 1.25rem;
    min-width: 0;
    width: 100%;
    max-width: 100%;
  }

  /* ── Contact ── */
  .contact-inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 100%;
    min-width: 0;
    width: 100%;
  }

  .contact-heading {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text);
    overflow-wrap: anywhere;
  }

  @media (max-width: 640px) {
    .skill-chip {
      white-space: normal;
      max-width: 100%;
    }
  }

  .contact-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* ── Highlight ── */
  .highlight {
    border-color: #F59E0B !important;
    transition: all 0.5s ease;
  }

  /* ── AI Rainbow Gradient Border for MailClient ── */
  .ai-gradient-border {
    position: relative;
    border: 2px solid transparent;
    border-radius: 12px;
    background:
      linear-gradient(var(--bg-surface), var(--bg-surface)) padding-box,
      linear-gradient(
        45deg,
        rgba(255, 0, 150, 0.4),
        rgba(0, 204, 255, 0.4),
        rgba(128, 0, 255, 0.4),
        rgba(255, 204, 0, 0.4),
        rgba(255, 0, 150, 0.4)
      ) border-box;
    background-size: 100% 100%, 300% 300%;
    background-position: 0 0, 0% 0%;
    animation: aiGradientShift 8s ease-in-out infinite;
  }

  .ai-gradient-border:hover {
    animation-duration: 4s;
  }

  /* Final mobile overrides placed late so they are not overridden by base rules above */
  @media (max-width: 768px) {
    .hero-shell {
      padding: 0 1rem;
    }

    .hero-inner {
      max-width: 100%;
      padding: 6rem 0 4rem;
    }

    .hero-name {
      font-size: clamp(2.2rem, 13vw, 4.5rem);
    }

    .hero-bio {
      max-width: 100%;
      font-size: 1rem;
    }

    .hero-photo-wrap {
      display: none;
