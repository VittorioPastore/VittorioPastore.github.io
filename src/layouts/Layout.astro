---
// Astro front matter remains the same
import '@fontsource/poppins';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <!-- Added viewport-fit=cover to handle safe areas -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- SEO Metadata -->
    <meta name="description" content="Vittorio Pastore's personal website and portfolio showcasing robotics engineering projects and skills" />
    <meta name="keywords" content="software engineer, full stack developer, AI, Reinforcement Learning, software development, portfolio" />
    <meta name="author" content="Vittorio Pastore" />

    <!-- Preload default (dark) background image at highest priority -->
    <link rel="preload" as="image" href="/back3.webp" fetchpriority="high" />

    <!-- Apply theme class + preload correct bg before first paint -->
    <script>
      (function() {
        var saved = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var isLight = saved === 'light' || (!saved && !prefersDark);
        if (isLight) {
          document.documentElement.classList.add('light-mode');
          // Also preload the light background
          var link = document.createElement('link');
          link.rel = 'preload';
          link.as = 'image';
          link.href = '/back5.webp';
          link.setAttribute('fetchpriority', 'high');
          document.head.appendChild(link);
        }
      })();
    </script>
  </head>

  <body>
    <!-- Shutdown Overlay -->
    <div id="shutdown-overlay" class="fixed inset-0 bg-black z-[99999] flex-col items-center justify-center p-4 md:p-8 font-mono hidden opacity-0 transition-opacity duration-500" style="font-family: 'Courier New', 'Lucida Console', 'Consolas', monospace;">
      <pre id="shutdown-log" class="whitespace-pre font-bold text-center m-0 p-0 leading-tight text-xs md:text-sm"></pre>
      <div id="shutdown-text" class="mt-8 text-center text-gray-400 text-sm md:text-base h-12 flex flex-col items-center justify-center">
        <div id="shutdown-status" class="font-bold text-white mb-2 !text-white"></div>
        <div id="shutdown-subtext" class="text-xs opacity-70 !text-gray-400"></div>
      </div>
    </div>

    <!-- Fixed background container for smooth transitioning -->
    <div class="fixed-background"></div>
    <div class="stars"></div>
    <div class="glow-orb"></div>
    <!-- Subtle Centered Toggle Buttons -->
    <div class="absolute top-4 left-1/2 -translate-x-1/2 flex gap-3 z-50">
      <button
        type="button"
        id="theme-toggle"
        class="toggle-button glass px-4 py-2 rounded-full transition-all duration-300 opacity-70 hover:opacity-100 flex items-center gap-2 text-xs md:text-sm text-white"
        title="Toggle Theme"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 theme-toggle-icon" viewBox="0 0 24 24" stroke="currentColor" fill="none">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <span class="font-medium whitespace-nowrap">Theme</span>
      </button>

      <button
        type="button"
        id="reboot-button"
        class="reboot-button glass px-4 py-2 rounded-full transition-all duration-300 opacity-70 hover:opacity-100 hover:bg-red-500/20 flex items-center gap-2 text-xs md:text-sm text-white"
        title="Reboot System"
      >
        <span class="text-lg leading-none">⏻</span>
        <span class="font-medium whitespace-nowrap">Reboot</span>
      </button>
    </div>

    <!-- Page Content -->
    <slot />

    <!-- Home Button -->
    <a
      href="/"
      id="home-button"
      class="fixed bottom-8 left-1/2 -translate-x-1/2 glass px-6 py-3 rounded-full text-white font-medium 
             hover:bg-white/20 transition-all duration-300 flex items-center gap-2 z-50 translate-y-0"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2"
        stroke="currentColor"
        class="w-5 h-5"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 
             .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 
             1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"
        />
      </svg>
      Home
    </a>

    <!-- Scroll & Link Scripts -->
    <script>
      // Fade background in once the image has loaded
      (function() {
        var isLight = document.documentElement.classList.contains('light-mode');
        var bgUrl = isLight ? '/back5.webp' : '/back3.webp';
        var bgEl = document.querySelector('.fixed-background');
        var img = new Image();
        img.onload = function() {
          if (bgEl) bgEl.style.opacity = '1';
        };
        img.onerror = function() {
          if (bgEl) bgEl.style.opacity = '1';
        };
        img.src = bgUrl;
      })();

      // Theme handling
      const html = document.documentElement;
      const themeToggle = document.getElementById('theme-toggle');
      const themeIcon = themeToggle?.querySelector('.theme-toggle-icon');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)');
      
      const updateThemeUI = (isDark) => {
        if (themeIcon) {
          if (isDark) {
            // Show sun icon when in dark mode (click to switch to light)
            themeIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                     d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>`;
          } else {
            // Show moon icon when in light mode (click to switch to dark)
            themeIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                     d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>`;
          }
        }
      };

      const setTheme = (isDark) => {
        html.classList.toggle('light-mode', !isDark);
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        updateThemeUI(isDark);
      };

      // Initialize theme
      const savedTheme = localStorage.getItem('theme');
      const initialTheme = savedTheme ? savedTheme === 'dark' : prefersDark.matches;
      setTheme(initialTheme);

      // Toggle the theme on button click
      themeToggle?.addEventListener('click', () => {
        const currentDark = !(html.classList.contains('light-mode'));
        setTheme(!currentDark);
      });

      // Reboot handling
      const rebootButton = document.getElementById('reboot-button');
      rebootButton?.addEventListener('click', async () => {
        const shutdownOverlay = document.getElementById('shutdown-overlay');
        const shutdownLog = document.getElementById('shutdown-log');
        const shutdownStatus = document.getElementById('shutdown-status');
        const shutdownSubtext = document.getElementById('shutdown-subtext');
        
        if (shutdownOverlay && shutdownLog && shutdownStatus && shutdownSubtext) {
          // Show overlay
          shutdownOverlay.classList.remove('hidden');
          shutdownOverlay.classList.add('flex');
          
          // Trigger fade in
          requestAnimationFrame(() => {
            shutdownOverlay.classList.remove('opacity-0');
            shutdownOverlay.classList.add('opacity-100');
          });

          document.documentElement.style.overflow = 'hidden';
          document.body.style.overflow = 'hidden';
          
          // Wait for fade in to complete
          await new Promise(resolve => setTimeout(resolve, 500));

          const asciiArt = [
            "⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢀⣀⣀⡀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀",
            "⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢸⣿⣿⡇⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀",
            "⠀⠀⠀⠀⠀⠀⠀⠀⣀⣤⣶⡆⠀⢸⣿⣿⡇⠀⢰⣶⣤⣀⠀⠀⠀⠀⠀⠀⠀⠀",
            "⠀⠀⠀⠀⠀⠀⣤⣾⣿⣿⡿⠇⠀⢸⣿⣿⡇⠀⠸⢿⣿⣿⣷⣤⠀⠀⠀⠀⠀⠀",
            "⠀⠀⠀⠀⣠⣾⣿⣿⠟⠁⠀⠀⠀⢸⣿⣿⡇⠀⠀⠀⠈⠻⣿⣿⣷⣄⠀⠀⠀⠀",
            "⠀⠀⠀⢠⣿⣿⡟⠁⠀⠀⠀⠀⠀⢸⣿⣿⡇⠀⠀⠀⠀⠀⠈⢻⣿⣿⡄⠀⠀⠀",
            "⠀⠀⠀⣿⣿⡟⠀⠀⠀⠀⠀⠀⠀⠸⠿⠿⠇⠀⠀⠀⠀⠀⠀⠀⢻⣿⣿⠀⠀⠀",
            "⠀⠀⢸⣿⣿⠁⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠈⣿⣿⡇⠀⠀",
            "⠀⠀⢸⣿⣿⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣿⣿⡇⠀⠀",
            "⠀⠀⠘⣿⣿⣇⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣸⣿⣿⠃⠀⠀",
            "⠀⠀⠀⢹⣿⣿⣄⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣠⣿⣿⡏⠀⠀⠀",
            "⠀⠀⠀⠀⢻⣿⣿⣦⡀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢀⣴⣿⣿⡟⠀⠀⠀⠀",
            "⠀⠀⠀⠀⠀⠙⢿⣿⣿⣶⣤⣀⠀⠀⠀⠀⠀⠀⣀⣤⣶⣿⣿⡿⠋⠀⠀⠀⠀⠀",
            "⠀⠀⠀⠀⠀⠀⠀⠈⠛⢿⣿⣿⣿⣿⣶⣶⣿⣿⣿⣿⡿⠛⠁⠀⠀⠀⠀⠀⠀⠀",
            "⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠉⠉⠛⠛⠛⠛⠉⠉⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀"
          ];

          const colors = new Array(asciiArt.length).fill('#4b5563'); // grey

          const render = () => {
            shutdownLog.innerHTML = asciiArt.map((row, i) => 
              `<span style="color: ${colors[i]}; text-shadow: 0 0 10px ${colors[i]}80; transition: color 0.1s ease-in-out; display: block;">${row}</span>`
            ).join('');
          };

          shutdownStatus.innerText = "Initiating Reboot Sequence...";
          shutdownSubtext.innerText = "Stopping services...";

          render();
          await new Promise(resolve => setTimeout(resolve, 600));

          shutdownStatus.innerText = "Powering Down...";
          shutdownSubtext.innerText = "Unmounting filesystems...";

          // Fade to red top to bottom (total ~400ms)
          for (let i = 0; i < asciiArt.length; i++) {
            colors[i] = '#ef4444'; // red
            render();
            await new Promise(resolve => setTimeout(resolve, 56));
          }

          shutdownStatus.innerText = "System Halted.";
          shutdownSubtext.innerText = "Preparing for restart...";

          await new Promise(resolve => setTimeout(resolve, 1000));

          shutdownStatus.innerText = "Rebooting...";
          shutdownSubtext.innerText = "Starting kernel...";

          // Turn green bottom to top (total ~400ms)
          for (let i = asciiArt.length - 1; i >= 0; i--) {
            colors[i] = '#22c55e'; // green
            render();
            await new Promise(resolve => setTimeout(resolve, 26));
          }

          shutdownStatus.innerText = "System Online.";
          shutdownSubtext.innerText = "Welcome back.";

          await new Promise(resolve => setTimeout(resolve, 1000));
        }

        sessionStorage.removeItem('hasBooted');
        sessionStorage.removeItem('safeGraphics');
        window.location.href = '/boot';
      });

      // Listen for system theme changes
      prefersDark.addEventListener('change', (e) => {
        setTheme(e.matches);
      });

      let lastScrollY = window.scrollY;
      let ticking = false;

      const homeButton = document.getElementById('home-button');
      
      const updateHomeButton = () => {
        if (!homeButton) return;
        
        const currentScrollY = window.scrollY;
        
        if (currentScrollY > lastScrollY) {
          // Scrolling down
          homeButton.style.transform = 'translate(-50%, 150%)';
        } else {
          // Scrolling up
          homeButton.style.transform = 'translate(-50%, 0)';
        }
        
        lastScrollY = currentScrollY;
        ticking = false;
      };

      const onScroll = () => {
        if (!ticking) {
          window.requestAnimationFrame(updateHomeButton);
          ticking = true;
        }
      };

      // Add scroll event listener
      window.addEventListener('scroll', onScroll, { passive: true });

      // Smooth scroll handler for internal links
      const smoothScroll = (e) => {
        const targetId = e.currentTarget.getAttribute('href');
        if (targetId && targetId.startsWith('#')) {
          e.preventDefault();
          const targetElement = document.querySelector(targetId);
          if (targetElement) {
            const targetPosition = targetElement.getBoundingClientRect().top + window.scrollY;
            window.scrollTo({
              top: targetPosition,
              behavior: 'smooth'
            });
          }
        }
      };

      // Add click handlers to all internal links
      document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
          anchor.addEventListener('click', smoothScroll);
        });
      });
    </script>
  </body>
</html>

<style is:global>
  /* ── Color tokens ── */
  :root {
    --bg-base: #111111;
    --bg-surface: #1a1a1a;
    --bg-elevated: #262626;
    --border-subtle: #2a2a2a;
    --border-hover: #404040;
    --color-text: #e5e5e5;
    --color-muted: #737373;
    --color-accent: #F59E0B;
  }

  html.light-mode {
    --bg-base: #f5f5f5;
    --bg-surface: #ffffff;
    --bg-elevated: #e5e5e5;
    --border-subtle: #d4d4d4;
    --border-hover: #a3a3a3;
    --color-text: #171717;
    --color-muted: #737373;
    --color-accent: #d97706;
  }

  /* ── Base ── */
  html {
    height: 100%;
    margin: 0;
    padding: 0;
    background-color: var(--bg-base);
    height: -webkit-fill-available;
  }

  body {
    display: flex;
    flex-direction: column;
    max-width: 1440px;
    margin: 0 auto;
    padding-top: 44px;
    padding-bottom: env(safe-area-inset-bottom);
    box-sizing: border-box;
    font-family: 'Poppins', sans-serif;
    color: var(--color-text);
    background-color: transparent;
    transition: color 0.3s ease, background-color 0.3s ease;
    height: 100vh;
    height: -webkit-fill-available;
  }

  /* ── Card: solid surface replacing glass ── */
  .card {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .card-hover:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  /* ── Text helpers ── */
  .text-muted {
    color: var(--color-muted);
  }

  .text-accent {
    color: var(--color-accent);
  }

  /* ── Section label: monospace terminal callback ── */
  .section-label {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.75rem;
    color: var(--color-muted);
    letter-spacing: 0.05em;
  }

  /* ── Nav bar ── */
  .site-nav {
    background: var(--bg-surface);
    border-bottom: 1px solid var(--border-subtle);
  }

  .nav-button {
    color: var(--color-muted);
    transition: color 0.2s ease, background-color 0.2s ease;
    border-radius: 6px;
  }

  .nav-button:hover {
    color: var(--color-text);
    background-color: var(--bg-elevated);
  }

  /* ── Home button ── */
  .home-button {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    color: var(--color-text);
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  .home-button:hover {
    border-color: var(--border-hover);
    background-color: var(--bg-elevated);
  }

  /* ── .float is intentionally a no-op (animation removed) ── */
  .float { }

  @supports (-webkit-touch-callout: none) {
    html { background-attachment: scroll; }
  }
</style>
